{
  "name": "menu-generator",
  "version": "0.1.0",
  "private": true,
  "homepage": "https://taichoup.github.io/menu-generator",
  "dependencies": {
    "@emotion/react": "^11.13.3",
    "@emotion/styled": "^11.13.0",
    "@mui/material": "^6.1.6",
    "@types/node": "^20.0.0",
    "@types/react": "^17.0.0",
    "@types/react-dom": "^17.0.0",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "react": "^17.0.1",
    "react-dom": "^17.0.1",
    "typescript": "^5.6.3",
    "vite": "^6.4.2",
    "vite-plugin-svgr": "^5.2.0",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "scripts": {
    "start": "vite",
    "build": "tsc && vite build",
    "serve": "vite preview",
    "lint": "eslint src",
    "test": "vitest",
    "test:coverage": "vitest run --coverage --watch=false",
    "predeploy": "yarn build",
    "deploy": "gh-pages -d dist"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.0.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "gh-pages": "^6.3.0",
    "jsdom": "^25.0.1",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "overrides": {
      "vite": "^6.4.2"
    },
    "onlyBuiltDependencies": ["@swc/core", "esbuild"]
  },
  "type": "module"
}
